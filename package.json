{
  "name": "@nettoolskit/ui",
  "version": "0.0.1-preview.2",
  "description": "Shared Vue 3 + Quasar component library with theme system, composables, and design tokens",
  "main": "./.build/dist/index.js",
  "module": "./.build/dist/index.mjs",
  "types": "./.build/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./.build/dist/index.d.ts",
      "import": "./.build/dist/index.mjs",
      "require": "./.build/dist/index.js"
    },
    "./styles": {
      "types": "./.build/dist/src/styles/index.d.ts",
      "import": "./.build/dist/styles.mjs",
      "require": "./.build/dist/styles.js"
    },
    "./quasar": {
      "types": "./.build/dist/src/quasar.d.ts",
      "import": "./.build/dist/quasar.mjs",
      "require": "./.build/dist/quasar.js"
    },
    "./router": {
      "types": "./.build/dist/src/router.d.ts",
      "import": "./.build/dist/router.mjs",
      "require": "./.build/dist/router.js"
    },
    "./styles/tokens.scss": "./src/styles/tokens.scss",
    "./styles/global.scss": "./src/styles/global.scss",
    "./styles/themes.css": "./src/styles/themes.css",
    "./styles/quasar-variables.scss": "./src/styles/quasar-variables.scss",
    "./design-system/tokens.css": "./src/design-system/tokens/generated.css",
    "./design-system/resolver.json": "./src/design-system/tokens/resolver.json",
    "./package.json": "./package.json"
  },
  "files": [
    ".build/dist",
    "src/styles",
    "src/design-system/tokens/generated.css",
    "src/design-system/tokens/generated",
    "src/design-system/tokens/resolver.json",
    "policies/design-system-css-governance.yaml",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css",
    "*.scss",
    "src/styles/**",
    "src/design-system/tokens/generated.css",
    "src/design-system/tokens/generated/tokens.css"
  ],
  "scripts": {
    "build": "npm run build:js && npm run build:dts",
    "build:js": "tsup",
    "build:dts": "vue-tsc --declaration --emitDeclarationOnly --outDir .build/dist && node scripts/emit-dist-entry-dts.mjs",
    "build:samples": "vite build",
    "dev": "npm run dev:samples",
    "dev:samples": "vite",
    "dev:lib": "tsup --watch",
    "prepublishOnly": "npm run build",
    "docs:build": "node scripts/design-system-docs.mjs",
    "docs:check": "node scripts/design-system-docs.mjs --check",
    "tokens:build": "node scripts/token-build.mjs",
    "tokens:check": "node scripts/token-build.mjs --check",
    "layers:check": "node scripts/check-layers.mjs --check",
    "layers:report": "node scripts/check-layers.mjs",
    "test": "cross-env VITE_CJS_IGNORE_WARNING=true vitest run --config tests/vitest.config.ts --pool=forks --maxWorkers=1 --no-file-parallelism --isolate=false",
    "test:architecture": "cross-env VITE_CJS_IGNORE_WARNING=true vitest run --config tests/vitest.config.ts tests/architecture",
    "test:design-system": "cross-env VITE_CJS_IGNORE_WARNING=true vitest run --config tests/vitest.config.ts tests/unit/design-system --pool=forks --maxWorkers=1 --no-file-parallelism --isolate=false",
    "test:tokens": "cross-env VITE_CJS_IGNORE_WARNING=true vitest run --config tests/vitest.config.ts tests/unit/design-system/tokens/token-build.spec.ts --environment=node --pool=forks --maxWorkers=1 --no-file-parallelism",
    "test:e2e": "playwright test",
    "test:watch": "cross-env VITE_CJS_IGNORE_WARNING=true vitest --config tests/vitest.config.ts",
    "test:coverage": "cross-env VITE_CJS_IGNORE_WARNING=true vitest run --coverage --config tests/vitest.config.ts --pool=forks --maxWorkers=1 --no-file-parallelism --isolate=false",
    "test:ui": "cross-env VITE_CJS_IGNORE_WARNING=true vitest --ui --config tests/vitest.config.ts",
    "lint": "eslint src samples --ext .ts,.vue",
    "lint:style": "stylelint \"src/**/*.css\"",
    "lint:css": "node scripts/lint-css-governance.mjs",
    "sec:audit": "npm audit --omit=dev --audit-level=high",
    "sec:lockfile": "lockfile-lint --path package-lock.json --type npm --allowed-hosts npm --validate-https --validate-integrity",
    "size:check": "node scripts/check-bundle-size.mjs",
    "type-check": "vue-tsc --noEmit",
    "verify": "npm run sec:audit && npm run sec:lockfile && npm run tokens:check && npm run docs:check && npm run layers:check && npm run lint -- --quiet && npm run lint:style && npm run lint:css && npm run type-check && npm run test:coverage && npm run build && npm run size:check && npm run build:samples && npm run test:e2e"
  },
  "keywords": [
    "vue",
    "vue3",
    "quasar",
    "components",
    "ui-library",
    "design-system",
    "typescript"
  ],
  "author": "Thiago Guislotti",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NetToolsKit/nettoolskit-ui.git"
  },
  "peerDependencies": {
    "quasar": "^2.0.0",
    "vue": "^3.0.0",
    "vue-router": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "quasar": {
      "optional": true
    },
    "vue-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@quasar/vite-plugin": "^1.12.0",
    "@types/node": "^26.0.1",
    "@types/three": "^0.185.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.11",
    "axe-core": "^4.12.1",
    "cross-env": "^10.1.0",
    "esbuild-plugin-vue3": "^0.5.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "lockfile-lint": "^5.0.0",
    "quasar": "^2.20.1",
    "sass": "^1.101.0",
    "stylelint": "^17.13.0",
    "three": "^0.185.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.18",
    "vue": "^3.5.38",
    "vue-eslint-parser": "^10.4.1",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.5"
  },
  "dependencies": {
    "@quasar/extras": "^2.0.1"
  }
}