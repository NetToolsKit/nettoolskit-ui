{
  "name": "nettoolskit",
  "version": "1.1.0",
  "description": "Shared Vue 3 + Quasar component library with theme system, composables, and design tokens",
  "main": "./.build/dist/index.js",
  "module": "./.build/dist/index.mjs",
  "types": "./.build/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./.build/dist/index.d.ts",
      "import": "./.build/dist/index.mjs",
      "require": "./.build/dist/index.js"
    },
    "./styles": {
      "types": "./.build/dist/src/styles/index.d.ts",
      "import": "./.build/dist/styles.mjs",
      "require": "./.build/dist/styles.js"
    },
    "./styles/tokens.scss": "./src/styles/tokens.scss",
    "./styles/global.scss": "./src/styles/global.scss",
    "./styles/themes.css": "./src/styles/themes.css",
    "./styles/quasar-variables.scss": "./src/styles/quasar-variables.scss",
    "./design-system/tokens.css": "./src/design-system/tokens/generated.css",
    "./design-system/resolver.json": "./src/design-system/tokens/resolver.json",
    "./package.json": "./package.json"
  },
  "files": [
    ".build/dist",
    "src/styles",
    "src/design-system/tokens/generated.css",
    "src/design-system/tokens/generated",
    "src/design-system/tokens/resolver.json",
    "policies/design-system-css-governance.yaml",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css",
    "*.scss",
    "src/styles/**",
    "src/design-system/tokens/generated.css",
    "src/design-system/tokens/generated/tokens.css"
  ],
  "scripts": {
    "build": "npm run build:js && npm run build:dts",
    "build:js": "tsup",
    "build:dts": "vue-tsc --declaration --emitDeclarationOnly --outDir .build/dist",
    "build:samples": "vite build",
    "build:landing": "npm run build:samples",
    "dev": "npm run dev:samples",
    "dev:samples": "vite",
    "dev:landing": "npm run dev:samples",
    "dev:lib": "tsup --watch",
    "prepublishOnly": "npm run build",
    "docs:build": "node scripts/design-system-docs.mjs",
    "docs:check": "node scripts/design-system-docs.mjs --check",
    "tokens:build": "node scripts/token-build.mjs",
    "tokens:check": "node scripts/token-build.mjs --check",
    "test": "cross-env VITE_CJS_IGNORE_WARNING=true vitest run --config tests/vitest.config.ts",
    "test:architecture": "cross-env VITE_CJS_IGNORE_WARNING=true vitest run --config tests/vitest.config.ts tests/architecture",
    "test:design-system": "cross-env VITE_CJS_IGNORE_WARNING=true vitest run --config tests/vitest.config.ts tests/unit/design-system --pool=forks --maxWorkers=1 --no-file-parallelism --isolate=false",
    "test:tokens": "cross-env VITE_CJS_IGNORE_WARNING=true vitest run --config tests/vitest.config.ts tests/unit/design-system/tokens/token-build.spec.ts --environment=node --pool=forks --maxWorkers=1 --no-file-parallelism",
    "test:a11y": "playwright test tests/e2e/design-system-a11y.spec.ts --workers=1",
    "test:visual": "playwright test tests/e2e/template-runtime-visual.spec.ts tests/e2e/cms-visual-regression.spec.ts --workers=1",
    "test:browser-gates": "playwright test tests/e2e/design-system-a11y.spec.ts tests/e2e/template-runtime-visual.spec.ts tests/e2e/cms-visual-regression.spec.ts --workers=1",
    "test:watch": "cross-env VITE_CJS_IGNORE_WARNING=true vitest --config tests/vitest.config.ts",
    "test:coverage": "cross-env VITE_CJS_IGNORE_WARNING=true vitest run --coverage --config tests/vitest.config.ts",
    "test:ui": "cross-env VITE_CJS_IGNORE_WARNING=true vitest --ui --config tests/vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "lint": "eslint src samples --ext .ts,.vue",
    "lint:style": "stylelint \"src/**/*.css\"",
    "lint:css": "node scripts/lint-css-governance.mjs",
    "type-check": "vue-tsc --noEmit",
    "verify": "npm run tokens:check && npm run docs:check && npm run lint -- --quiet && npm run lint:style && npm run lint:css && npm run type-check && npm run test:design-system && npm run test:architecture && npm run test:browser-gates && npm run build"
  },
  "keywords": [
    "vue",
    "vue3",
    "quasar",
    "components",
    "ui-library",
    "design-system",
    "typescript"
  ],
  "author": "Thiago Guislotti",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThiagoGuislotti/nettoolskit-ui.git"
  },
  "peerDependencies": {
    "quasar": "^2.0.0",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.61.0",
    "@quasar/vite-plugin": "^1.12.0",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.50.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.11",
    "cross-env": "^7.0.3",
    "esbuild-plugin-vue3": "^0.5.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^24.0.0",
    "quasar": "^2.20.1",
    "sass": "^1.101.0",
    "stylelint": "^17.13.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vite": "^6.0.5",
    "vitest": "^4.0.18",
    "vue": "^3.5.38",
    "vue-eslint-parser": "^9.4.3",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.0.0"
  },
  "dependencies": {
    "@quasar/extras": "^1.17.0",
    "highcharts": "12.5.0"
  }
}